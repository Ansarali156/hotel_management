{
  "name": "safestay-backend",
  "version": "1.0.0",
  "description": "SafeStay Network — Government-grade dual-portal hotel surveillance and management backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate --schema=src/database/prisma/schema.prisma && tsc",
    "start": "npx prisma generate --schema=src/database/prisma/schema.prisma && node dist/index.js",
    "prisma:migrate": "npx prisma migrate dev --schema=src/database/prisma/schema.prisma",
    "prisma:deploy": "npx prisma migrate deploy --schema=src/database/prisma/schema.prisma",
    "prisma:generate": "npx prisma generate --schema=src/database/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=src/database/prisma/schema.prisma",
    "seed": "ts-node src/database/seeds/policeRanks.ts",
    "seed:officer": "ts-node src/database/seeds/defaultOfficer.ts",
    "seed:demo": "ts-node src/database/seeds/comprehensive-seed.ts",
    "seed:all": "npm run seed && npm run seed:officer && npm run seed:demo",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "prisma": {
    "schema": "src/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@indic-transliteration/sanscript": "^1.3.3",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "@upstash/redis": "^1.37.0",
    "argon2": "^0.31.2",
    "bullmq": "^5.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.1.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.2",
    "prisma": "^6.19.3",
    "redis": "^4.6.13",
    "resend": "^6.10.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.12.0",
    "yamljs": "^0.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^6.4.23",
    "@types/pdfkit": "^0.17.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/yamljs": "^0.2.34",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
