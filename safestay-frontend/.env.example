# ── API ────────────────────────────────────────────────────────────────────────
# In dev, leave empty — Vite proxies /api to localhost:4000 automatically.
# In production, set to your backend URL (e.g. https://your-backend.onrender.com/api/v1)
VITE_API_BASE_URL=

# ── Portal mode ────────────────────────────────────────────────────────────────
# Set to "police" for police-only deployment (root redirects to /police/login)
VITE_PORTAL=

# ── Firebase (optional — only needed if using Firebase features) ───────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
